# Copy to .env and adjust as needed:  cp .env.example .env

# --- Kafka (Confluent Cloud) ---
KAFKA_BOOTSTRAP_SERVERS=pkc-921jm.us-east-2.aws.confluent.cloud:9092
KAFKA_TOPIC_PREFIX=ticks
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=3

# --- Kafka auth (SASL_SSL) ---
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
# Confluent Cloud API key = SASL username, API secret = SASL password.
KAFKA_API_KEY=your-confluent-api-key
KAFKA_API_SECRET=your-confluent-api-secret

# --- Binance ---
# Symbols to stream (comma-separated, lowercase, no slash).
BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt
# Public market-data mirror (not geo-blocked). The main wss://stream.binance.com:9443
# endpoint returns HTTP 451 from US IPs.
BINANCE_WS_BASE=wss://data-stream.binance.vision

# --- Producer ---
LOG_LEVEL=INFO
# Emit a throughput summary every N seconds (0 disables).
STATS_INTERVAL_SECONDS=10

# --- GCP / BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=/Users/diegokervabon/claude/crypto/keys/crypto-microstructure-c3badd2c329c.json
GCP_PROJECT_ID=crypto-microstructure
BQ_LOCATION=US
BQ_RAW_DATASET=crypto_raw
BQ_RAW_TABLE=ticks
BQ_MARTS_DATASET=crypto_marts

# --- Kafka -> BigQuery consumer ---
KAFKA_CONSUMER_GROUP=crypto-bq-consumer
KAFKA_OFFSET_RESET=earliest
BQ_BATCH_SIZE=500
BQ_FLUSH_SECONDS=5
